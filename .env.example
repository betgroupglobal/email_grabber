# --- Postgres ---
POSTGRES_USER=email_grabber
POSTGRES_PASSWORD=change_me_locally
POSTGRES_DB=email_grabber
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Lead pipeline (FastAPI) ---
# 32+ random bytes, hex or base64. Used to sign double-opt-in tokens.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
LEAD_PIPELINE_SECRET_KEY=replace-me-with-a-long-random-string
LEAD_PIPELINE_BASE_URL=http://localhost:8000
LEAD_PIPELINE_FROM_EMAIL=noreply@example.com
LEAD_PIPELINE_FROM_NAME=BetGroup Research

# Resend (https://resend.com) — leave blank to log emails to stdout instead.
RESEND_API_KEY=

# --- Crawler ---
CRAWLER_USER_AGENT=BetGroupResearchBot/0.1 (+mailto:research@betgroupglobal.example)
CRAWLER_CONCURRENT_REQUESTS=4
CRAWLER_DOWNLOAD_DELAY=1.0
# Set to 1 to enable Scrapy-Redis distributed mode (off by default).
CRAWLER_USE_REDIS=0
